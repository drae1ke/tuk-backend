PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
PUBLIC_API_BASE_URL=http://localhost:5000
MONGODB_URI=mongodb://127.0.0.1:27017/tookride
JWT_SECRET=replace-with-a-strong-secret

# Business timezone for commission settlement windows
BUSINESS_TIMEZONE=Africa/Nairobi
COMMISSION_RATE=0.10
ENABLE_COMMISSION_SCHEDULER=true
COMMISSION_AUTO_STK_PUSH=false

# Daraja / M-Pesa
MPESA_ENV=sandbox
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your-daraja-passkey
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL=http://localhost:5000/api/payments/callback
MPESA_CALLBACK_TOKEN=replace-with-a-random-callback-token
MPESA_REQUEST_TIMEOUT_MS=15000
MPESA_STK_RETRY_WINDOW_MS=120000

# Optional email notifications
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=notifications@example.com
EMAIL_PASS=replace-with-email-password
# Set to true only if your network has working outbound IPv6 (avoids preferring A records).
# EMAIL_SMTP_USE_IPV6=true
